<!DOCTYPE html>
<html lang={current_ui_locale(@conn)} phx-socket={live_socket_path(@conn)}>
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, shrink-to-fit=no, user-scalable=no"/>
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title><%= assigns[:page_title] || t("ExLingo Dashboard") %></title>
    <link rel="icon" href={asset_path(@conn, :favicon)} sizes="any">
    <link rel="icon" href={asset_path(@conn, :favicon_svg)} type="image/svg+xml">
    <link rel="stylesheet" nonce={csp_nonce(@conn, :style)} href={asset_path(@conn, :css)}>
    <script nonce={csp_nonce(@conn, :script)} src={asset_path(@conn, :js)} defer></script>
    <script>
      if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark')
      } else {
        document.documentElement.classList.remove('dark')
      }

      window.addEventListener("toggle_dark_mode", (event) => {
        if (localStorage.theme === 'dark') {
          localStorage.setItem("theme", "light")
          document.documentElement.classList.remove('dark')
        } else {
          localStorage.setItem("theme", "dark")
          document.documentElement.classList.add('dark')
        }
      });
    </script>
  </head>
  <body class="ex-lingo-dashboard">
    <.sidebar_provider>
      <.sidebar id="sidebar" collapsible="icon">
        <.sidebar_header>
          <.app_side_nav title="ExLingo" />
        </.sidebar_header>
        <.sidebar_separator />
        <.sidebar_content>
          <.sidebar_group>
            <.sidebar_group_label>{t("Workspace")}</.sidebar_group_label>
            <.sidebar_group_content>
              <.sidebar_menu>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/dashboard")}>
                    <.icon name="dashboard" decorative /> <span>{t("Dashboard")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/locales")}>
                    <.icon name="translate" decorative /> <span>{t("Locales")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/domains")}>
                    <.icon name="folder_managed" decorative /> <span>{t("Domains")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/contexts")}>
                    <.icon name="category" decorative /> <span>{t("Contexts")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/application_sources")}>
                    <.icon name="apps" decorative /> <span>{t("Applications")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/glossary")}>
                    <.icon name="book" decorative /> <span>{t("Glossary")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
                <.sidebar_menu_item>
                  <.sidebar_menu_button href={dashboard_path(@conn, "/possible_duplicates")}>
                    <.icon name="difference" decorative /> <span>{t("Possible duplicates")}</span>
                  </.sidebar_menu_button>
                </.sidebar_menu_item>
              </.sidebar_menu>
            </.sidebar_group_content>
          </.sidebar_group>
        </.sidebar_content>
      </.sidebar>

      <.sidebar_inset>
        <.topbar data-ex-lingo-topbar>
          <div class="mr-auto" />
          <.locale_select class="ml-2" />
          <.button
            type="button"
            variant="ghost"
            size="icon"
            phx-click={Phoenix.LiveView.JS.dispatch("toggle_dark_mode")}
            aria-label={t("Toggle dark mode")}
          >
            <.icon name="dark_mode" size="sm" decorative />
          </.button>
        </.topbar>

        <.page>
          <.page_content data-ex-lingo-page-content>
            <%= @inner_content %>
          </.page_content>
        </.page>
      </.sidebar_inset>
    </.sidebar_provider>
</body>
</html>
